# ========== 代理服务器端口 ==========
PORT=19901

# ========== 上游 API 配置（必填） ==========
UPSTREAM_BASE_URL=https://your-upstream-api.example.com
UPSTREAM_API_KEY=sk-your-api-key

# ========== 思考配置 ==========
# 默认深度: quick | standard | deep
DEFAULT_THINKING_DEPTH=standard

# 是否自动解析回复中的 thinking/answer 标签并作为独立字段返回
PARSE_THINKING_RESPONSE=true
